# Build-time envs for production.
#
# Google Analytics 4 (иначе компонент GA не рендерится и сканеры пишут «нет счётчиков»)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
#
# Emergency-safe default: CDN assetPrefix OFF.
# To enable later, set BOTH vars and configure CORS on cdn.yappix.ru for /_next/static/*:
# ENABLE_CDN_ASSETPREFIX=1
# NEXT_PUBLIC_CDN_URL=https://cdn.yappix.ru
