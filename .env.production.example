# NEXT_PUBLIC_* are inlined at build time.
#
# Emergency default: keep CDN disabled until CORS is verified in production.
# To enable CDN assetPrefix later, uncomment and ensure cdn.yappix.ru returns
# Access-Control-Allow-Origin: https://yappix.ru for /_next/static/*
# NEXT_PUBLIC_CDN_URL=https://cdn.yappix.ru
