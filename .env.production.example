# Скопируйте в .env.production на сервере или задайте те же переменные в CI/PM2.
# NEXT_PUBLIC_* встраиваются в клиентский бандл на этапе `pnpm run build`.

# Статика Next.js: `/_next/static/*` должна отдаваться с CDN (тот же origin-pull или зеркало), иначе сайт сломается.
# Нужен CORS: Access-Control-Allow-Origin: https://yappix.ru (если браузер тянет чанки с другого хоста).
NEXT_PUBLIC_CDN_URL=https://cdn.yappix.ru
