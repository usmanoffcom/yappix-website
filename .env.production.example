# Build-time envs for production.
#
# Google Analytics 4 (иначе компонент GA не рендерится и сканеры пишут «нет счётчиков»)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
#
# Публичный URL сайта (OpenRouter Referer, дефолтный webhook URL без TELEGRAM_WEBHOOK_URL).
# После смены — `pnpm build` в deploy (NEXT_PUBLIC_* участвуют в клиентском бандле).
NEXT_PUBLIC_APP_URL=https://yappix.ru
#
# `NEXT_PUBLIC_CDN_URL` = только assetPrefix для /_next/static (JS/CSS). Не для /images/ из public/.
# CORS: deploy/nginx-cdn-cors.conf (cdn → proxy /_next/static → origin).
# Чтобы отключить CDN-чанки: CDN_OFF=1 bash scripts/deploy.sh
# NEXT_PUBLIC_CDN_URL=https://cdn.yappix.ru

# ─── OpenRouter (`/api/chat`). Без ключа — 503. Алиас имени: OPENROUTER_KEY.
# Залить с Mac: scripts/upload-env-to-vds.sh → /var/www/yappix.ru/.env.production
# OPENROUTER_API_KEY=sk-or-v1-your-key-from-openrouter.ai
# При 400/404 от модели: OPENROUTER_MODEL=openai/gpt-4o-mini (или другая с openrouter.ai)

# ─── SMTP (лиды / бронирование, Nodemailer) ───
# Логин: SMTP_EMAIL или SMTP_USER (полный email). Пароль: SMTP_PASSWORD.
#
# Mail.ru (пример):
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=587
# (587/465: TLS выставляется по порту; SMTP_SECURE не обязателен)
# SMTP_USER=sales@yappix.ru
# SMTP_PASSWORD=...
# SMTP_FROM=sales@yappix.ru
# SMTP_TO=sales@yappix.ru
#
# Gmail: SMTP_HOST=smtp.gmail.com + пароль приложения
# SMTP_EMAIL=your@gmail.com
# SMTP_PASSWORD=app-password

# ─── Prisma CMS (блог / кейсы / шаблоны) на VDS ───
# Файл БД лежит в каталоге приложения — тот же cwd, что у `next start` и у `scripts/deploy.sh`.
USE_CMS_DB=1
DATABASE_URL="file:./prisma/production.db"

# ─── Telegram (лиды + @yappix_bot webhook) ───
# TELEGRAM_BOT_TOKEN=
# Алиас: TELEGRAM_CHAT_ID (то же, что TELEGRAM_LEADS_CHAT_ID)
# TELEGRAM_LEADS_CHAT_ID=
# Должен совпадать с secret_token при setWebhook (POST /api/telegram-setup)
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_URL=https://yappix.ru/api/telegram/webhook
#
# Если с VDS таймаут до api.telegram.org (бот не отвечает) или до openrouter.ai:
# Пример рабочего Squid (только с IP основного VDS): 
# HTTPS_PROXY=http://167.99.139.49:3128
# TELEGRAM_HTTPS_PROXY=...
# OPENROUTER_HTTPS_PROXY=...
