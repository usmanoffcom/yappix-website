# Скопируйте в deploy/vds.env и подправьте (deploy/vds.env в .gitignore не добавляем —
# храните локально или экспортируйте переменные перед ssh).

# SSH к VDS (ключ с дефисом: myunion-vds)
export VDS_SSH_KEY="${HOME}/.ssh/myunion-vds"
export VDS_USER="root"
export VDS_HOST="89.23.102.48"
export VDS_YAPIX_DIR="/var/www/yappix.ru"

# Пример одной команды деплоя с Mac:
# ssh -i "$VDS_SSH_KEY" -o IdentitiesOnly=yes "$VDS_USER@$VDS_HOST" \
#   "cd $VDS_YAPIX_DIR && git fetch origin main && git reset --hard origin/main && bash scripts/deploy.sh"
